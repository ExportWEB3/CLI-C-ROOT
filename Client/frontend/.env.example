# Frontend environment — copy to .env and fill in your values

# === DEV ONLY (used by Vite proxy during `npm run dev`) ===
# Point to your bridge API and WebSocket servers
VITE_API_URL=http://localhost:8081
VITE_WS_URL=ws://localhost:8080

# === PRODUCTION ===
# In production these are NOT needed if you use nginx to reverse proxy
# /api  -> port 8081
# /ws-bridge -> port 8080
# The frontend auto-detects ws://<your-domain>/ws-bridge at runtime.
